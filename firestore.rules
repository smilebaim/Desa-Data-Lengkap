rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Profil pengguna: hanya pemilik yang bisa baca/tulis
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Menu Navigasi: Publik bisa baca, hanya staf terautentikasi bisa tulis
    match /menus/{menuId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Desa dan Laporan: Publik bisa baca, hanya staf terautentikasi bisa tulis
    match /villages/{villageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /reports/{reportId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}