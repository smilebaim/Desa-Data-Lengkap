
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Data profil pengguna",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "avatarUrl": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "Konfigurasi item menu navigasi",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "icon": { "type": "string" },
        "href": { "type": "string" },
        "order": { "type": "number" },
        "position": { "type": "string", "enum": ["bottom", "left", "header"] }
      },
      "required": ["label", "icon", "position", "order"]
    },
    "Village": {
      "title": "Village",
      "description": "Data administratif dan spasial desa",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "province": { "type": "string" },
        "population": { "type": "number" },
        "area": { "type": "number" },
        "idmScore": { "type": "number", "description": "Indeks Desa Membangun (0.00 - 1.00)" },
        "budgetAllocation": { "type": "number", "description": "Anggaran Desa (Rp)" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "boundary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        },
        "description": { "type": "string" },
        "tagline": { "type": "string" },
        "potentials": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "location"]
    },
    "MapFeature": {
      "title": "Map Feature",
      "description": "Objek spasial tambahan",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "showStats": { "type": "boolean" },
        "type": { "type": "string", "enum": ["marker", "polyline", "circle", "polygon", "rectangle"] },
        "category": { "type": "string" },
        "icon": { "type": "string" },
        "geometry": { "type": "object" },
        "properties": { "type": "object" }
      },
      "required": ["name", "type", "geometry"]
    },
    "DynamicPage": {
      "title": "Dynamic Page",
      "description": "Halaman konten kustom",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "showStats": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    },
    "Visualizer": {
      "title": "Visualizer",
      "description": "Konfigurasi grafik kustom",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "metric": { "type": "string", "enum": ["population", "area", "density", "idmScore", "budgetAllocation"] },
        "chartType": { "type": "string", "enum": ["bar", "pie", "line", "area", "radar", "composed", "scatter"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "metric", "chartType"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Data pengguna"
    },
    "/menus/{menuId}": {
      "schema": { "$ref": "#/entities/MenuItem" },
      "description": "Navigasi"
    },
    "/villages/{villageId}": {
      "schema": { "$ref": "#/entities/Village" },
      "description": "Desa"
    },
    "/features/{featureId}": {
      "schema": { "$ref": "#/entities/MapFeature" },
      "description": "Aset Peta"
    },
    "/pages/{pageId}": {
      "schema": { "$ref": "#/entities/DynamicPage" },
      "description": "Halaman"
    },
    "/visualizers/{visualizerId}": {
      "schema": { "$ref": "#/entities/Visualizer" },
      "description": "Grafik"
    }
  }
}

    