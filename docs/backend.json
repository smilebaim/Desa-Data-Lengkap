
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Data profil pengguna",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "avatarUrl": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Pengaturan identitas aplikasi global",
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "appSlogan": { "type": "string" },
        "logoType": { "type": "string", "enum": ["icon", "image"] },
        "logoIcon": { "type": "string" },
        "logoUrl": { "type": "string" }
      },
      "required": ["appName"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "Konfigurasi item menu navigasi",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "icon": { "type": "string" },
        "href": { "type": "string" },
        "order": { "type": "number" },
        "position": { "type": "string", "enum": ["bottom", "left", "header"] }
      },
      "required": ["label", "icon", "position", "order"]
    },
    "Village": {
      "title": "Village",
      "description": "Data administratif dan spasial desa",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "province": { "type": "string" },
        "population": { "type": "number" },
        "area": { "type": "number" },
        "idmScore": { "type": "number" },
        "budgetAllocation": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "boundary": { "type": "array" },
        "description": { "type": "string" },
        "tagline": { "type": "string" },
        "potentials": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "location"]
    },
    "MapFeature": {
      "title": "Map Feature",
      "description": "Objek spasial tambahan",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "icon": { "type": "string" },
        "geometry": { "type": "object" },
        "properties": { "type": "object" }
      },
      "required": ["name", "type", "geometry"]
    },
    "DynamicPage": {
      "title": "Dynamic Page",
      "description": "Halaman konten kustom",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "showStats": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    },
    "Visualizer": {
      "title": "Visualizer",
      "description": "Konfigurasi grafik kustom",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "metric": { "type": "string" },
        "chartType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "metric", "chartType"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/entities/UserProfile" }, "description": "Profil pengguna" },
    "/settings/{settingId}": { "schema": { "$ref": "#/entities/AppSettings" }, "description": "Pengaturan Global" },
    "/menus/{menuId}": { "schema": { "$ref": "#/entities/MenuItem" }, "description": "Navigasi" },
    "/villages/{villageId}": { "schema": { "$ref": "#/entities/Village" }, "description": "Data Desa" },
    "/features/{featureId}": { "schema": { "$ref": "#/entities/MapFeature" }, "description": "Fitur Peta" },
    "/pages/{pageId}": { "schema": { "$ref": "#/entities/DynamicPage" }, "description": "Halaman" },
    "/visualizers/{visualizerId}": { "schema": { "$ref": "#/entities/Visualizer" }, "description": "Visualisasi" }
  }
}
