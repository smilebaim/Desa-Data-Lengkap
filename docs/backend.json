
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Data profil pengguna",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "avatarUrl": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "Konfigurasi item menu navigasi",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "icon": { "type": "string", "description": "Nama ikon Lucide" },
        "href": { "type": "string" },
        "order": { "type": "number" },
        "position": { "type": "string", "enum": ["bottom", "left", "header"] }
      },
      "required": ["label", "icon", "position", "order"]
    },
    "Village": {
      "title": "Village",
      "description": "Data administratif dan spasial desa",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "province": { "type": "string" },
        "population": { "type": "number" },
        "area": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "boundary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        }
      },
      "required": ["name", "location"]
    },
    "MapFeature": {
      "title": "Map Feature",
      "description": "Objek spasial tambahan (Marker, Line, POI)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["marker", "polyline", "circle"] },
        "category": { "type": "string" },
        "icon": { "type": "string" },
        "geometry": { "type": "object" },
        "properties": { "type": "object" }
      },
      "required": ["name", "type", "geometry"]
    },
    "DynamicPage": {
      "title": "Dynamic Page",
      "description": "Halaman konten kustom yang dapat dibuat oleh admin",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "slug": { "type": "string" },
        "showStats": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Data pengguna sistem"
    },
    "/menus/{menuId}": {
      "schema": { "$ref": "#/entities/MenuItem" },
      "description": "Koleksi item menu dinamis"
    },
    "/villages/{villageId}": {
      "schema": { "$ref": "#/entities/Village" },
      "description": "Data spasial desa"
    },
    "/features/{featureId}": {
      "schema": { "$ref": "#/entities/MapFeature" },
      "description": "Data overlay peta (POI, Jalan, Aset)"
    },
    "/pages/{pageId}": {
      "schema": { "$ref": "#/entities/DynamicPage" },
      "description": "Koleksi halaman dinamis"
    }
  }
}
