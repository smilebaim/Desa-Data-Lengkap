
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Data profil pengguna",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "avatarUrl": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "Konfigurasi item menu navigasi",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "icon": { "type": "string", "description": "Nama ikon Lucide (misal: User, Map, Layers)" },
        "href": { "type": "string" },
        "order": { "type": "number" },
        "position": { "type": "string", "enum": ["bottom", "left", "header"] }
      },
      "required": ["label", "icon", "position", "order"]
    },
    "Village": {
      "title": "Village",
      "description": "Data administratif dan spasial desa",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "province": { "type": "string" },
        "population": { "type": "number" },
        "area": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "boundary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        }
      },
      "required": ["name", "location"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Data pengguna sistem"
    },
    "/menus/{menuId}": {
      "schema": { "$ref": "#/entities/MenuItem" },
      "description": "Koleksi item menu dinamis untuk navigasi utama"
    },
    "/villages/{villageId}": {
      "schema": { "$ref": "#/entities/Village" },
      "description": "Data spasial dan demografi desa"
    }
  }
}
